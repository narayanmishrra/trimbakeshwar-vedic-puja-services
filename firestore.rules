rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Config collection rules
    match /config/images {
      // Public is allowed to read config images so the website can fetch dynamic URLs
      allow read: if true;
      // Writing is strictly handled by the admin SDK / backend seed scripts, so client writes are denied
      allow write: if false;
    }
  }
}
